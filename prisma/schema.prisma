generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"

}

model User {
  id      Int    @id @default(autoincrement())
  name    String
  email   String @unique
  password String
  role    String @default("CLIENT")   // SUPERADMIN / ADMIN / CLIENT
  status  String @default("PENDING")  // PENDING / ACTIVE / SUSPENDED

  orgName String?

  // --- SAFETY FIELDS ---
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  deletedBy   Int?
  suspendedAt DateTime?
  suspendedBy Int?
  // ---------------------

  whatsappConfig WhatsAppConfig?
  contacts       Contact[]
  campaigns      Campaign[]
  agents         Agent[]
  messages       Message[]

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  @@index([email])
  @@index([isDeleted])
  @@index([status])
}

model WhatsAppConfig {
  id            Int     @id @default(autoincrement())
  userId        Int     @unique
  phoneNumberId String
  accessToken   String
  verifyToken   String
  displayNumber String
  businessId    String?
  isActive      Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  // NoAction = SQL Server equivalent of Restrict
  // Blocks hard delete of User if config exists
  user User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@index([phoneNumberId])
}

model Agent {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  password String
  userId   Int

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  // NoAction: blocks hard delete of User if agents exist
  user     User      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  contacts Contact[]

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  @@index([userId])
  @@index([isDeleted])
}

model Contact {
  id              Int     @id @default(autoincrement())
  name            String?
  phone           String
  optIn           Boolean @default(true)
  userId          Int
  assignedAgentId Int?

  // NoAction: blocks hard delete of User if contacts exist
  user          User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  // NoAction: contact stays if agent is soft-deleted
  assignedAgent Agent?   @relation(fields: [assignedAgentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  messages      Message[]

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  @@unique([userId, phone])
  @@index([userId])
  @@index([assignedAgentId])
}

model Campaign {
  id               Int     @id @default(autoincrement())
  name             String
  message          String
  messageType      String  @default("TEXT")
  templateName     String?
  templateLanguage String? @default("en_US")
  templateParams   String?
  status           String  @default("PENDING") // PENDING / RUNNING / COMPLETED / FAILED
  userId           Int
  phoneNumberId    String  @default("")

  // NoAction: preserves full campaign history
  user     User      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  messages Message[]

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  @@index([userId])
  @@index([phoneNumberId])
  @@index([status])
}

model Message {
  id            Int       @id @default(autoincrement())
  userId        Int
  campaignId    Int?
  contactId     Int
  status        String
  direction     String    @default("OUTBOUND") // INBOUND / OUTBOUND
  body          String?
  whatsappMsgId String?
  errorReason   String?
  sentAt        DateTime?
  deliveredAt   DateTime?
  readAt        DateTime?
  retryCount    Int       @default(0)
  mediaId       String?
  mediaType     String?
  mediaUrl      String?
  mediaName     String?

  createdAt DateTime @default(now())

  // NoAction on all: messages are permanent audit records
  contact  Contact   @relation(fields: [contactId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user     User      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@index([campaignId])
  @@index([contactId])
  @@index([whatsappMsgId])
  @@index([status])
}